# Model Configuration for ChemSpace Copilot
# =====================================
# This file controls which LLM backend ChemSpace Copilot uses.
# Edit the values below or override them with environment variables
# (MODEL_PROVIDER, MODEL_ID, OLLAMA_HOST).

# provider: "deepseek" (cloud API), "openrouter" (OpenRouter gateway), or "ollama" (local model)
provider=deepseek

# Model ID (provider-specific)
# For deepseek: "deepseek-chat", "deepseek-reasoner"
# For openrouter: any OpenRouter model id, e.g. "deepseek/deepseek-v3.2", "openai/gpt-5-mini"
# For ollama: any model available on your Ollama instance, e.g. "llama3.1", "qwen2.5:72b"
model_id=deepseek-chat

# Ollama host (only used when provider=ollama, optional)
# Default: http://localhost:11434
# In Docker: use http://host.docker.internal:11434 to reach host Ollama
# ollama_host=http://localhost:11434
